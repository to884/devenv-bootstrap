# ============================================================================
# Dev Environment Bootstrap - .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# Ansible 関連
# ----------------------------------------------------------------------------
*.retry
.ansible/
ansible.log
*.log

# Ansible Galaxy インストール済みロール（通常は除外）
# ansible/roles/external/

# ----------------------------------------------------------------------------
# Python 仮想環境
# ----------------------------------------------------------------------------
.venv/
venv/
env/
.env/
ENV/
.ansible-venv/

# Python キャッシュとコンパイル済みファイル
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
dist/
build/

# ----------------------------------------------------------------------------
# セキュリティ・機密情報
# ----------------------------------------------------------------------------
*.pem
*.key
*.crt
.secrets/
secrets.yml
vault-password.txt

# 環境変数ファイル（機密情報を含む可能性）
.env.local
.env.*.local

# ----------------------------------------------------------------------------
# エディタ・IDE
# ----------------------------------------------------------------------------
.idea/
*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/

# ----------------------------------------------------------------------------
# OS 固有
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ----------------------------------------------------------------------------
# 一時ファイル・キャッシュ
# ----------------------------------------------------------------------------
*.tmp
tmp/
.cache/
.temp/

# ----------------------------------------------------------------------------
# バックアップファイル
# ----------------------------------------------------------------------------
*.bak
*.backup
*~

# ----------------------------------------------------------------------------
# ログとレポート
# ----------------------------------------------------------------------------
*.log
logs/
reports/

# ----------------------------------------------------------------------------
# テスト・開発用
# ----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/


#Ignore vscode AI rules
.github\instructions\codacy.instructions.md
