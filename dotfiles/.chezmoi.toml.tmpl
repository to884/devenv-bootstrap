# ============================================================================
# .chezmoi.toml - chezmoi 設定ファイル（テンプレート）
# ============================================================================
#
# このファイルはchezmoiの初期化時に ~/.config/chezmoi/chezmoi.toml として
# コピーされます。ユーザー固有の情報を設定してください。
#
# 編集する場合は: chezmoi edit-config
#
# ============================================================================

{{- $name := promptStringOnce . "name" "氏名を入力してください" -}}
{{- $email := promptStringOnce . "email" "メールアドレスを入力してください" -}}
{{- $github_user := promptStringOnce . "github_user" "GitHubユーザー名を入力してください (オプション)" -}}

[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
{{- if $github_user }}
    github_user = {{ $github_user | quote }}
{{- end }}
